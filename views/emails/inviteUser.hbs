<div style="background:#ffffff; padding:26px 0; font-family: 'Segoe UI', Arial, sans-serif; color:#1f2937;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="max-width:640px; margin:0 auto; background:#ffffff; border-collapse:separate;">
    <tr>
      <td style="padding:30px 34px 22px 34px; text-align:center; background:linear-gradient(180deg, {{brandPrimaryColorLight}} 0%, {{brandPrimaryColorLighter}} 44%, #ffffff 100%); color:#163b73; border:1px solid #ecf1f8; border-bottom:0;">
        <div style="width:88px; height:88px; margin:0 auto 14px auto; background:{{brandPrimaryColorSoftest}}; border-radius:14px; display:flex; align-items:center; justify-content:center; overflow:hidden; border:1px solid #eef2f7;">
          {{#if logoUrl}}
            <img src="{{logoUrl}}" alt="{{brandName}} logo" style="max-width:74px; max-height:74px; object-fit:contain; display:block;">
          {{else}}
            <div style="width:56px; height:56px; border-radius:50%; background:{{brandPrimaryColor}}; color:#ffffff; font-size:18px; font-weight:700; line-height:56px; text-align:center;">{{logoFallbackText}}</div>
          {{/if}}
        </div>
        <div style="font-size:13px; letter-spacing:0.4px; opacity:0.9;">
          {{#if portalLabel}}{{portalLabel}}{{else}}{{brandName}} Admin Portal{{/if}}
        </div>
        <h2 style="margin:8px 0 0 0; font-size:30px; line-height:1.2; color:#0e2f5f;">
          {{#if heading}}{{heading}}{{else}}You are invited{{/if}}
        </h2>
      </td>
    </tr>
    <tr>
      <td style="padding:2px 34px 8px 34px; font-size:16px; line-height:1.7; border:1px solid #ecf1f8; border-top:0; border-bottom:0;">
        <p style="margin:0 0 12px 0;">Hi {{name}},</p>
        <p style="margin:0 0 14px 0;">
          {{#if introLine}}
            {{{introLine}}}
          {{else}}
            {{invitedBy}} invited you to collaborate inside <strong>{{brandName}}</strong> admin.
          {{/if}}
        </p>

        {{#if isRegistrationInvite}}
          <p style="margin:0 0 14px 0;">
            {{#if registrationLine}}
              {{{registrationLine}}}
            {{else}}
              Use the button below to set a new password and complete secure access to your admin account.
            {{/if}}
          </p>
        {{else}}
          <p style="margin:0 0 14px 0;">
            {{#if signInLine}}
              {{{signInLine}}}
            {{else}}
              Your account is already set up. Click below to sign in and continue where you left off.
            {{/if}}
          </p>
        {{/if}}
      </td>
    </tr>
    <tr>
      <td style="padding:0 34px 18px 34px; text-align:center; border-left:1px solid #ecf1f8; border-right:1px solid #ecf1f8;">
        {{#if isRegistrationInvite}}
          <a href="{{registrationUrl}}" style="display:inline-block; text-decoration:none; background:{{brandPrimaryColor}}; color:#ffffff; padding:13px 24px; border-radius:10px; font-weight:600;">
            {{#if registrationButtonText}}{{registrationButtonText}}{{else}}Set Password & Continue{{/if}}
          </a>
        {{else}}
          <a href="{{loginUrl}}" style="display:inline-block; text-decoration:none; background:{{brandPrimaryColor}}; color:#ffffff; padding:13px 24px; border-radius:10px; font-weight:600;">
            {{#if signInButtonText}}{{signInButtonText}}{{else}}Sign In to Admin{{/if}}
          </a>
        {{/if}}
      </td>
    </tr>
    <tr>
      <td style="padding:0 34px 20px 34px; border-left:1px solid #ecf1f8; border-right:1px solid #ecf1f8;">
        <div style="background:#f7f9fe; border:1px solid #e3ebff; border-radius:10px; padding:14px 14px; font-size:14px; color:#475569;">
          {{#if isRegistrationInvite}}
            {{#if registrationHint}}{{registrationHint}}{{else}}This registration link expires in 72 hours for your security.{{/if}}
          {{else}}
            {{#if signInHint}}{{signInHint}}{{else}}If you forgot your password, you can reset it anytime.{{/if}}
            {{#if forgotPasswordUrl}}<a href="{{forgotPasswordUrl}}" style="color:{{brandPrimaryColor}}; text-decoration:none;">Reset password</a>{{/if}}
          {{/if}}
        </div>
      </td>
    </tr>
    <tr>
      <td style="padding:0 34px 28px 34px; font-size:13px; color:#6b7280; line-height:1.6; border:1px solid #ecf1f8; border-top:0;">
        If you were not expecting this invitation, you can safely ignore this email.
        <br/><br/>
        With care,<br/>
        {{brandName}} Team
      </td>
    </tr>
  </table>
</div>
