<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">Forgot password</h2>
                <p class="text-secondary mb-4 text-center">Enter your email and we’ll send you a reset link.</p>
                <form autocomplete="off" novalidate="">
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <input type="email" class="form-control" placeholder="your@email.com" autocomplete="off">
                    </div>
                    <div class="form-footer">
                        <button type="button" id="submit-btn" class="btn btn-primary w-100"
                            onclick="requestReset()">Send reset link</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/login">Back to login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const requestReset = async () => {
        const elemHTML = $('#submit-btn').html();
        $('form').find('.alert').remove();
        try {
            const email = $('input[type="email"]').val();
            if (!email) {
                $(".form-footer").after(`
                <div class="alert alert-danger mt-4" role="alert">
                    <h4 class="alert-title">Invalid!</h4>
                    <div class="text-secondary">Please enter your email address.</div>
                </div>`);
                return;
            }

            $('#submit-btn').html(`
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                Processing
            `);

            const response = await $.ajax({
                url: '/forgot-password',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ email })
            });

            $(".form-footer").after(`
            <div class="alert alert-success mt-4" role="alert">
                <h4 class="alert-title">Done</h4>
                <div class="text-secondary">${response.message}</div>
            </div>`);
        } catch (error) {
            $(".form-footer").after(`
            <div class="alert alert-danger mt-4" role="alert">
              <h4 class="alert-title">Request failed</h4>
              <div class="text-secondary">${error.responseJSON?.error || error.responseText || 'Unable to process request.'}</div>
            </div>`);
        }
        $('#submit-btn').html(elemHTML);
    };

    $('form').on('submit', function (e) {
        e.preventDefault();
        requestReset();
    });
</script>
