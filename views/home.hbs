<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-end">
            <div class="col">
                <div class="page-pretitle">Dashboard</div>
                <h2 class="page-title">{{#if settings.brandName}}{{settings.brandName}}{{else}}Dedicated Parents{{/if}} Admin Portal</h2>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row row-deck row-cards">
            <div class="col-sm-6 col-lg-3">
                <a href="/causes" class="card text-reset text-decoration-none h-100">
                    <div class="card-body">
                        <div class="subheader">Causes</div>
                        <div class="h1 mb-0">{{causeCount}}</div>
                        <div class="text-muted">Active: {{activeCauseCount}}</div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 col-lg-3">
                <a href="/events" class="card text-reset text-decoration-none h-100">
                    <div class="card-body">
                        <div class="subheader">Events</div>
                        <div class="h1 mb-0">{{eventCount}}</div>
                        <div class="text-muted">Upcoming active: {{upcomingEventCount}}</div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 col-lg-3">
                <a href="/gallery" class="card text-reset text-decoration-none h-100">
                    <div class="card-body">
                        <div class="subheader">Gallery</div>
                        <div class="h1 mb-0">{{galleryCount}}</div>
                        <div class="text-muted">Gallery images</div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 col-lg-3">
                <a href="/team" class="card text-reset text-decoration-none h-100">
                    <div class="card-body">
                        <div class="subheader">Team</div>
                        <div class="h1 mb-0">{{teamCount}}</div>
                        <div class="text-muted">Team members</div>
                    </div>
                </a>
            </div>
        </div>

        <div class="row row-deck row-cards mt-1">
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header"><h3 class="card-title">Content Collections</h3></div>
                    <div class="list-group list-group-flush">
                        <a class="list-group-item list-group-item-action" href="/pages">Pages</a>
                        <a class="list-group-item list-group-item-action" href="/blogs">Blogs</a>
                        <a class="list-group-item list-group-item-action" href="/causes">Causes</a>
                        <a class="list-group-item list-group-item-action" href="/events">Events</a>
                        <a class="list-group-item list-group-item-action" href="/gallery">Gallery</a>
                        <a class="list-group-item list-group-item-action" href="/team">Team</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header"><h3 class="card-title">Recent Tickets</h3></div>
                    <div class="list-group list-group-flush">
                        {{#if recentTickets.length}}
                            {{#each recentTickets}}
                                <a class="list-group-item list-group-item-action" href="/tickets/{{this._id}}">
                                    <div class="fw-semibold">{{#if this.name}}{{this.name}}{{else}}Ticket #{{this._id}}{{/if}}</div>
                                    <div class="text-muted">{{#if this.service}}{{this.service}}{{else}}General{{/if}}</div>
                                </a>
                            {{/each}}
                        {{else}}
                            <div class="list-group-item"><div class="text-muted">No tickets yet.</div></div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header"><h3 class="card-title">Recent Subscriptions</h3></div>
                    <div class="list-group list-group-flush">
                        {{#if recentSubscriptions.length}}
                            {{#each recentSubscriptions}}
                                <div class="list-group-item">
                                    <div class="fw-semibold">{{this.email}}</div>
                                    <div class="text-muted">{{formatDate this.createdAt}}</div>
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="list-group-item"><div class="text-muted">No subscriptions yet.</div></div>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-deck row-cards mt-1">
            <div class="col-12">
                <div class="card">
                    <div class="card-header"><h3 class="card-title">Recent Activity Logs</h3></div>
                    <div class="list-group list-group-flush">
                        {{#if recentLogs.length}}
                            {{#each recentLogs}}
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-semibold">{{this.message}}</div>
                                            <div class="text-muted d-flex flex-wrap gap-2 mt-1">
                                                {{#if this.user}}
                                                    <span class="badge bg-blue-lt text-blue">{{this.user.name}}</span>
                                                {{else}}
                                                    <span class="badge bg-blue-lt text-blue">System</span>
                                                {{/if}}
                                                <span>{{capitalizeFirstLetter this.action}} · {{capitalizeFirstLetter this.entityType}}</span>
                                            </div>
                                        </div>
                                        <div class="badge bg-secondary-lt text-secondary">{{formatTime this.createdAt}}</div>
                                    </div>
                                </div>
                            {{/each}}
                        {{else}}
                            <div class="list-group-item"><div class="text-muted">No activity yet.</div></div>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>