<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md">
            <div class="card-body">
                {{#if note}}
                <h2 class="h3 text-center mb-4">{{note}}</h2>
                {{else}}
                <h2 class="h2 text-center mb-4">Sign in to Admin</h2>
                {{/if}}
                {{#if success}}
                <div class="alert alert-success" role="alert">{{success}}</div>
                {{/if}}
                <form autocomplete="off" novalidate="">
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <input type="email" class="form-control" placeholder="your@email.com" autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="••••••••" autocomplete="current-password">
                    </div>
                    <div class="form-footer">
                        <button type="button" id="submit-btn" class="btn btn-primary w-100"
                            onclick="loginWithPassword()">Sign in</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/forgot-password">Forgot password?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const loginWithPassword = async () => {
        const elemHTML = $('#submit-btn').html();
        $('form').find('.alert').remove();
        try {
            const email = $('input[type="email"]').val();
            const password = $('input[type="password"]').val();
            if (!email || !password) {
                $(".form-footer").after(`
                <div class="alert alert-danger mt-4" role="alert">
                    <h4 class="alert-title">Invalid!</h4>
                    <div class="text-secondary">Please fill in both email and password.</div>
                </div>`);
                return;
            };
            $('#submit-btn').html(`
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    Processing
                `);
            const response = await $.ajax({
                url: '/login',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    email,
                    password,
                })
            });

            if (response.success) {
                window.location.href = '/dashboard';
            }
        } catch (error) {
            $(".form-footer").after(`
            <div class="alert alert-danger mt-4" role="alert">
              <h4 class="alert-title">Login failed!</h4>
              <div class="text-secondary">${error.responseJSON?.error || error.responseText || 'Unable to sign in.'}</div>
            </div>`);
            console.error('Error logging in:', error);
        }
        $('#submit-btn').html(elemHTML);
    };


    $('form').on('submit', function (e) {
        e.preventDefault();
        loginWithPassword();
    });
</script>
