<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">Reset password</h2>
                {{#if note}}
                <div class="alert alert-warning" role="alert">{{note}}</div>
                {{/if}}
                {{#if invalidToken}}
                <div class="text-center">
                    <a href="/forgot-password" class="btn btn-primary">Request new reset link</a>
                    <div class="mt-3"><a href="/login">Back to login</a></div>
                </div>
                {{else}}
                <form autocomplete="off" novalidate="">
                    <input type="hidden" id="token" value="{{token}}">
                    <div class="mb-3">
                        <label class="form-label">New password</label>
                        <input type="password" class="form-control" id="password" placeholder="••••••••" autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm new password</label>
                        <input type="password" class="form-control" id="confirmPassword" placeholder="••••••••" autocomplete="off">
                    </div>
                    <div class="form-footer">
                        <button type="button" id="submit-btn" class="btn btn-primary w-100"
                            onclick="resetPassword()">Update password</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/login">Back to login</a>
                    </div>
                </form>
                {{/if}}
            </div>
        </div>
    </div>
</div>

<script>
    const resetPassword = async () => {
        const elemHTML = $('#submit-btn').html();
        $('form').find('.alert').remove();
        try {
            const token = $('#token').val();
            const password = $('#password').val();
            const confirmPassword = $('#confirmPassword').val();

            if (!token || !password || !confirmPassword) {
                $(".form-footer").after(`
                <div class="alert alert-danger mt-4" role="alert">
                    <h4 class="alert-title">Invalid!</h4>
                    <div class="text-secondary">Please complete all fields.</div>
                </div>`);
                return;
            }

            $('#submit-btn').html(`
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                Processing
            `);

            const response = await $.ajax({
                url: '/reset-password',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ token, password, confirmPassword })
            });

            if (response.success) {
                window.location.href = '/dashboard';
            }
        } catch (error) {
            $(".form-footer").after(`
            <div class="alert alert-danger mt-4" role="alert">
              <h4 class="alert-title">Reset failed</h4>
              <div class="text-secondary">${error.responseJSON?.error || error.responseText || 'Unable to reset password.'}</div>
            </div>`);
        }
        $('#submit-btn').html(elemHTML);
    };

    $('form').on('submit', function (e) {
        e.preventDefault();
        resetPassword();
    });
</script>
