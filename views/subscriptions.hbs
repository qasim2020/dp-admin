<!-- Page header -->
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <div class="page-pretitle">Subscriptions</div>
        <h2 class="page-title">Subscriber Emails</h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <a href="/subscriptions/download" class="btn btn-outline-primary">
            <i class="ti ti-download icon"></i>
            Download CSV
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="card">
      <div class="card-body d-none d-lg-block">
        <div class="row row-cards">
          {{#each desktopColumns}}
            <div class="col-lg-3">
              <div class="list-group list-group-flush border rounded">
                {{#if this.length}}
                  {{#each this}}
                    <div class="list-group-item">
                      <div class="fw-medium text-truncate">{{this.email}}</div>
                      <div class="text-secondary small">{{formatDate this.createdAt}}</div>
                    </div>
                  {{/each}}
                {{else}}
                  <div class="list-group-item text-secondary">No entries</div>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>
      </div>

      <div class="card-body d-lg-none">
        <div class="list-group list-group-flush border rounded">
          {{#if mobileSubscriptions.length}}
            {{#each mobileSubscriptions}}
              <div class="list-group-item">
                <div class="fw-medium text-truncate">{{this.email}}</div>
                <div class="text-secondary small">{{formatDate this.createdAt}}</div>
              </div>
            {{/each}}
          {{else}}
            <div class="list-group-item text-center text-secondary">No subscriptions yet.</div>
          {{/if}}
        </div>
      </div>

      {{#if desktopPagination.totalPages}}
        <div class="card-footer d-none d-lg-flex align-items-center">
          <p class="m-0 text-secondary">
            Showing <span>{{desktopMeta.showing}}</span> of <span>{{desktopPagination.total}}</span> emails (4 columns × 10)
          </p>
          <ul class="pagination m-0 ms-auto">
            <li class="page-item {{#unless desktopPagination.hasPrev}}disabled{{/unless}}">
              <a class="page-link" href="/subscriptions?pageDesktop={{desktopPagination.prevPage}}&pageMobile={{currentPages.pageMobile}}" tabindex="-1" aria-disabled="{{#unless desktopPagination.hasPrev}}true{{/unless}}">
                <i class="ti ti-chevron-left"></i>
              </a>
            </li>
            {{#each desktopPagination.pages}}
              <li class="page-item {{#if this.active}}active{{/if}}">
                <a class="page-link" href="/subscriptions?pageDesktop={{this.number}}&pageMobile={{../currentPages.pageMobile}}">{{this.number}}</a>
              </li>
            {{/each}}
            <li class="page-item {{#unless desktopPagination.hasNext}}disabled{{/unless}}">
              <a class="page-link" href="/subscriptions?pageDesktop={{desktopPagination.nextPage}}&pageMobile={{currentPages.pageMobile}}" aria-disabled="{{#unless desktopPagination.hasNext}}true{{/unless}}">
                <i class="ti ti-chevron-right"></i>
              </a>
            </li>
          </ul>
        </div>
      {{/if}}

      {{#if mobilePagination.totalPages}}
        <div class="card-footer d-flex d-lg-none align-items-center">
          <p class="m-0 text-secondary">
            Showing <span>{{mobileMeta.showing}}</span> of <span>{{mobilePagination.total}}</span> emails (10 rows)
          </p>
          <ul class="pagination m-0 ms-auto">
            <li class="page-item {{#unless mobilePagination.hasPrev}}disabled{{/unless}}">
              <a class="page-link" href="/subscriptions?pageMobile={{mobilePagination.prevPage}}&pageDesktop={{currentPages.pageDesktop}}" tabindex="-1" aria-disabled="{{#unless mobilePagination.hasPrev}}true{{/unless}}">
                <i class="ti ti-chevron-left"></i>
              </a>
            </li>
            {{#each mobilePagination.pages}}
              <li class="page-item {{#if this.active}}active{{/if}}">
                <a class="page-link" href="/subscriptions?pageMobile={{this.number}}&pageDesktop={{../currentPages.pageDesktop}}">{{this.number}}</a>
              </li>
            {{/each}}
            <li class="page-item {{#unless mobilePagination.hasNext}}disabled{{/unless}}">
              <a class="page-link" href="/subscriptions?pageMobile={{mobilePagination.nextPage}}&pageDesktop={{currentPages.pageDesktop}}" aria-disabled="{{#unless mobilePagination.hasNext}}true{{/unless}}">
                <i class="ti ti-chevron-right"></i>
              </a>
            </li>
          </ul>
        </div>
      {{/if}}
    </div>
  </div>
</div>
